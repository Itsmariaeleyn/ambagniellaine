      <button class="add-row-btn" onclick="addRow()">+ Add Line Item</button>

      
      <div class="totals">
        <div class="totals-inner">
          <div class="total-row">
            <span class="total-label">Subtotal</span>
            <span class="total-val" id="subtotalVal">₱0.00</span>
          </div>
          <div class="total-row discount">
            <span class="total-label">Bulk discount (<input class="discount-input" id="discountPct" type="number" min="0" max="100" value="25.5" oninput="recalc()"/>%)</span>
            <span class="total-val" id="discountVal">-₱0.00</span>
