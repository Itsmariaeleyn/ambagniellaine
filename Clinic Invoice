            <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="09654875632"/><br>
            <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="PhilHealth Accredited Clinic"/>
          </div>
        </div>
        <div>
          <div class="party-label">Prepared By</div>
          <div class="party-name"><input class="editable" style="font-weight:700;font-size:13.5px;color:#1a2740;" value="MetroMed Diagnostic Corp"/></div>
          <div class="party-detail">
            <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="Buhay na Tubig, Imus Cavite"/><br>
            <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="09654875632"/><br>
            <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="PhilHealth Accredited Clinic"/>
          </div>
        </div>
      </div>

  
      <table class="inv-table" id="itemTable">
        <thead>
          <tr>
            <th style="width:36px;">#</th>
            <th>TEST / SERVICES</th>
            <th class="right" style="width:70px;">QTY</th>
            <th class="right" style="width:100px;">UNIT PRICE</th>
            <th class="right" style="width:100px;">BALANCE</th>
            <th style="width:32px;"></th>
