<div class="toast" id="toast">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" id="toastIcon">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
  <span id="toastMsg">Done!</span>
</div>

<script>
  
  function setNav(el) {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    el.classList.add('active');
  }

 
  const initialRows = [
    { service: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', qty: 14, price: 350 },
    { service: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', qty: 20, price: 220 },
    { service: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', qty: 10, price: 680 },
    { service: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', qty:  7, price: 550 },
  ];

  let rowId = 0;

  function addRow(data = {}) {
    const tbody = document.getElementById('tableBody');
    rowId++;
    const id = rowId;
    const service = data.service || '';
    const detail  = data.detail  || '';
    const qty     = data.qty   !== undefined ? data.qty   : 1;
    const price   = data.price !== undefined ? data.price : 0;

    const tr = document.createElement('tr');
    tr.id = 'row-' + id;
    tr.innerHTML = `
      <td class="num">${String(tbody.children.length + 1).padStart(2,'0')}</td>
      <td>
        <div class="td-service"><input class="table-input" placeholder="Service / test name" value="${service}" oninput="recalc()"/></div>
        <div class="td-service-sub"><input class="table-input" style="font-size:10.5px;color:#9aaabb;" placeholder="Details…" value="${detail}"/></div>
      </td>
      <td class="right"><input class="table-input right mono" type="number" min="0" value="${qty}" style="width:50px;" oninput="recalc()"/></td>
      <td class="right"><input class="table-input right mono" type="number" min="0" value="${price}" style="width:70px;" oninput="recalc()"/></td>
      <td class="right mono" id="bal-${id}">₱0.00</td>
      <td>
        <button class="row-delete" onclick="deleteRow(${id})" title="Remove row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </button>
      </td>`;
    tbody.appendChild(tr);
    recalc();
  }

  function deleteRow(id) {
    document.getElementById('row-' + id)?.remove();
    renumberRows();
    recalc();
  }

  function renumberRows() {
    document.querySelectorAll('#tableBody tr').forEach((tr, i) => {
      tr.querySelector('.num').textContent = String(i + 1).padStart(2, '0');
    });
  }

  function recalc() {
    let subtotal = 0;
    document.querySelectorAll('#tableBody tr').forEach(tr => {
      const inputs = tr.querySelectorAll('input[type="number"]');
      const qty   = parseFloat(inputs[0]?.value) || 0;
      const price = parseFloat(inputs[1]?.value) || 0;
      const bal   = qty * price;
      subtotal += bal;
      const balCell = tr.querySelector('[id^="bal-"]');
      if (balCell) balCell.textContent = '₱' + bal.toLocaleString('en-PH', {minimumFractionDigits:2});
    });
    const pct      = parseFloat(document.getElementById('discountPct').value) || 0;
    const discount = subtotal * (pct / 100);
    const total    = subtotal - discount;
    document.getElementById('subtotalVal').textContent = '₱' + subtotal.toLocaleString('en-PH', {minimumFractionDigits:2});
    document.getElementById('discountVal').textContent = '-₱' + discount.toLocaleString('en-PH', {minimumFractionDigits:2});
    document.getElementById('totalVal').textContent    = '₱' + total.toLocaleString('en-PH', {minimumFractionDigits:2});
  }

  function markAsPaid() {
    const badge = document.getElementById('statusBadge');
    if (badge.classList.contains('badge-paid')) {
      badge.className = 'badge-unpaid';
      badge.textContent = 'UNPAID';
      badge.title = 'Click to mark as paid';
      showToast('Invoice marked as Unpaid.', 'error');
    } else {
      badge.className = 'badge-paid';
      badge.textContent = 'PAID';
      badge.title = 'Click to mark as unpaid';
      showToast('Invoice marked as Paid!', 'success');
    }
  }

  
  function exportPDF() {
    showToast('Preparing PDF export…', 'success');
    setTimeout(() => window.print(), 400);
  }


  let toastTimer;
  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    const icon  = document.getElementById('toastIcon');
    document.getElementById('toastMsg').textContent = msg;
    toast.className = 'toast ' + type;
    if (type === 'success') {
      icon.innerHTML = `<polyline points="20 6 9 17 4 12"/>`;
    } else {
      icon.innerHTML = `<circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`;
    }
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  initialRows.forEach(r => addRow(r));
</script>
</body>
</html>
