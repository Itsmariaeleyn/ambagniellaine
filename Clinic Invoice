<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CLINIQ – Invoice</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'DM Sans', sans-serif; background: #f0f2f7; color: #1a2740; }

    
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; height: 52px;
      background: #5b7198; display: flex; align-items: center;
      padding: 0 20px; gap: 14px; z-index: 200;
    }
    .logo { display: flex; align-items: center; gap: 9px; color: #fff; font-size: 18px; font-weight: 800; letter-spacing: 2px; user-select: none; }
    .logo svg { width: 26px; height: 26px; }
    .topbar-search {
      flex: 1; max-width: 420px; height: 32px;
      background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.28);
      border-radius: 5px; padding: 0 12px; color: #fff; font-size: 13px; font-family: inherit; outline: none;
    }
    .topbar-search::placeholder { color: rgba(255,255,255,0.5); }

  
    .layout { display: flex; padding-top: 52px; min-height: 100vh; }

    
    .sidebar {
      width: 190px; flex-shrink: 0; background: #4e6490;
      position: fixed; top: 52px; left: 0; bottom: 0;
      display: flex; flex-direction: column; overflow-y: auto;
    }
    .user-card {
      display: flex; align-items: center; gap: 10px;
      padding: 14px; background: #3a4f72; margin: 10px 10px 0; border-radius: 8px;
    }
    .avatar { width: 36px; height: 36px; background: #2d3e5c; border-radius: 7px; color: #fff; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .user-name { color: #fff; font-size: 13px; font-weight: 600; line-height: 1.2; }
    .user-role { color: rgba(255,255,255,0.55); font-size: 10.5px; }
    .nav-group-label { color: rgba(255,255,255,0.45); font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 14px 16px 4px; }
    .nav-item { display: flex; align-items: center; gap: 9px; padding: 9px 16px; color: rgba(255,255,255,0.72); font-size: 13px; font-weight: 500; cursor: pointer; border-left: 3px solid transparent; transition: background 0.12s, color 0.12s; user-select: none; }
    .nav-item:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .nav-item.active { background: rgba(255,255,255,0.1); color: #fff; border-left-color: #fff; }
    .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; opacity: 0.8; }
    .nav-item.active svg { opacity: 1; }
    .nav-signout { margin-top: auto; display: flex; align-items: center; gap: 9px; padding: 10px 16px; color: rgba(255,255,255,0.65); font-size: 13px; cursor: pointer; border-left: 3px solid transparent; }
    .nav-signout:hover { background: rgba(255,255,255,0.07); color: #fff; }
    .nav-signout svg { width: 15px; height: 15px; }
    .sidebar-emblem { text-align: center; padding: 16px 0 20px; opacity: 0.2; }
    .sidebar-emblem svg { width: 52px; height: 52px; }

    
    .main { margin-left: 190px; flex: 1; padding: 32px 40px; min-height: calc(100vh - 52px); }

    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .page-title { font-size: 20px; font-weight: 700; color: #1a2740; }
    .page-actions { display: flex; gap: 10px; }
    .btn-ghost {
      background: #fff; border: 1.5px solid #dde3ef; border-radius: 7px;
      padding: 8px 16px; font-size: 13px; font-weight: 600; font-family: inherit;
      color: #3a4f72; cursor: pointer; display: flex; align-items: center; gap: 6px;
      transition: background 0.13s, border-color 0.13s;
    }
    .btn-ghost:hover { background: #f0f3f9; border-color: #b0bdd4; }
    .btn-ghost svg { width: 14px; height: 14px; }
    .btn-primary {
      background: #3a4f72; color: #fff; border: none; border-radius: 7px;
      padding: 8px 18px; font-size: 13px; font-weight: 600; font-family: inherit;
      cursor: pointer; display: flex; align-items: center; gap: 6px; transition: background 0.13s;
    }
    .btn-primary:hover { background: #2d3e5c; }
    .btn-primary svg { width: 14px; height: 14px; }
    .btn-success {
      background: #28c76f; color: #fff; border: none; border-radius: 7px;
      padding: 8px 18px; font-size: 13px; font-weight: 600; font-family: inherit;
      cursor: pointer; display: flex; align-items: center; gap: 6px; transition: background 0.13s;
    }
    .btn-success:hover { background: #1fae5e; }

    
    .invoice-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 4px 24px rgba(40,60,100,0.1), 0 1px 4px rgba(0,0,0,0.05);
      max-width: 820px; margin: 0 auto; padding: 40px 44px 44px;
    }

    .inv-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; }
    .inv-logo { display: flex; align-items: center; gap: 10px; }
    .inv-logo svg { width: 32px; height: 32px; }
    .inv-logo-name { font-size: 22px; font-weight: 800; color: #3a4f72; letter-spacing: 2px; }
    .inv-title-block { text-align: right; }
    .inv-title { font-size: 30px; font-weight: 800; color: #3a4f72; letter-spacing: 3px; margin-bottom: 8px; }
    .inv-meta { font-size: 11.5px; color: #7a8eaa; line-height: 1.9; }
    .inv-meta span { font-weight: 600; color: #1a2740; }
    .inv-meta .due-red { color: #e84057; font-weight: 700; }

    .badge-unpaid {
      display: inline-block; background: #fde8eb; color: #e84057;
      font-size: 10px; font-weight: 800; padding: 3px 10px; border-radius: 20px;
      letter-spacing: 1px; margin-top: 4px; cursor: pointer;
      border: 1.5px solid #f5b8c1; transition: background 0.13s;
    }
    .badge-unpaid:hover { background: #fbd0d6; }
    .badge-paid {
      display: inline-block; background: #e4f9ee; color: #28c76f;
      font-size: 10px; font-weight: 800; padding: 3px 10px; border-radius: 20px;
      letter-spacing: 1px; margin-top: 4px; border: 1.5px solid #a8ecc8;
    }

    .inv-clinic { font-size: 12.5px; color: #1a2740; font-weight: 600; margin-bottom: 2px; }
    .inv-clinic-sub { font-size: 11.5px; color: #7a8eaa; line-height: 1.7; }

    .inv-divider { border: none; border-top: 1.5px solid #eef0f7; margin: 22px 0; }

  
    .inv-parties { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    .party-label { font-size: 9.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #7a8eaa; margin-bottom: 6px; }
    .party-name { font-size: 13.5px; font-weight: 700; color: #1a2740; margin-bottom: 4px; }
    .party-detail { font-size: 11.5px; color: #7a8eaa; line-height: 1.8; }

    
    .editable {
      border: none; outline: none; font-family: inherit;
      background: transparent; width: 100%;
      border-bottom: 1.5px dashed transparent; transition: border-color 0.15s;
      padding: 1px 2px;
    }
    .editable:hover { border-bottom-color: #b0bdd4; }
    .editable:focus { border-bottom-color: #3a4f72; background: #f7f9fc; border-radius: 3px 3px 0 0; }

   
    .inv-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 12.5px; }
    .inv-table thead tr { background: #f0f3f9; }
    .inv-table th { padding: 10px 12px; text-align: left; font-size: 9.5px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: #7a8eaa; border-bottom: 1.5px solid #dde3ef; }
    .inv-table th.right { text-align: right; }
    .inv-table td { padding: 10px 12px; border-bottom: 1px solid #f0f2f7; vertical-align: middle; }
    .inv-table td.right { text-align: right; font-family: 'DM Mono', monospace; font-size: 12px; }
    .inv-table td.num { color: #7a8eaa; font-weight: 600; width: 36px; }
    .inv-table tbody tr:hover { background: #fafbfd; }
    .inv-table tbody tr:last-child td { border-bottom: none; }

    .td-service { font-weight: 600; color: #1a2740; }
    .td-service-sub { font-size: 10.5px; color: #9aaabb; margin-top: 2px; }

    .table-input {
      border: none; outline: none; font-family: inherit; background: transparent;
      width: 100%; font-size: 12.5px; color: #1a2740;
      border-bottom: 1.5px dashed transparent; transition: border-color 0.15s; padding: 1px 2px;
    }
    .table-input:hover { border-bottom-color: #b0bdd4; }
    .table-input:focus { border-bottom-color: #3a4f72; background: #f7f9fc; border-radius: 3px 3px 0 0; }
    .table-input.right { text-align: right; }
    .table-input.mono { font-family: 'DM Mono', monospace; }

    .row-delete {
      background: none; border: none; cursor: pointer;
      color: #ccd3e0; padding: 4px; border-radius: 4px; transition: color 0.13s, background 0.13s;
    }
    .row-delete:hover { color: #e84057; background: #fde8eb; }
    .row-delete svg { width: 13px; height: 13px; display: block; }

    .add-row-btn {
      background: none; border: 1.5px dashed #b0bdd4; border-radius: 7px;
      color: #8a98b0; font-size: 12px; font-weight: 600; font-family: inherit;
      padding: 8px 16px; cursor: pointer; width: 100%; margin-bottom: 20px;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .add-row-btn:hover { border-color: #3a4f72; color: #3a4f72; background: #f4f6fb; }

    .totals { display: flex; flex-direction: column; align-items: flex-end; gap: 0; margin-bottom: 24px; }
    .totals-inner { width: 300px; }
    .total-row { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid #f0f2f7; font-size: 13px; }
    .total-row:last-child { border-bottom: none; }
    .total-row.discount { background: #fde8eb; border-radius: 6px; padding: 7px 10px; margin: 4px 0; }
    .total-row.discount .total-label { color: #e84057; font-weight: 600; }
    .total-row.discount .total-val { color: #e84057; font-weight: 700; font-family: 'DM Mono', monospace; font-size: 12px; }
    .total-row.grand { border-top: 2px solid #dde3ef; padding-top: 10px; margin-top: 4px; }
    .total-label { color: #7a8eaa; font-size: 12px; }
    .total-val { font-family: 'DM Mono', monospace; font-size: 12.5px; font-weight: 600; color: #1a2740; }
    .total-row.grand .total-label { font-weight: 700; color: #1a2740; font-size: 13.5px; }
    .total-row.grand .total-val { color: #3a4f72; font-size: 14px; font-weight: 800; }

    .discount-input {
      border: none; outline: none; font-family: inherit; background: transparent;
      width: 60px; font-size: 12px; color: #e84057; font-weight: 600; text-align: right;
      border-bottom: 1.5px dashed #f5b8c1; transition: border-color 0.15s;
    }
    .discount-input:focus { border-bottom-color: #e84057; }

  
    .inv-footer { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .footer-block { background: #f8f9fc; border: 1px solid #eef0f7; border-radius: 9px; padding: 16px 18px; }
    .footer-label { font-size: 9.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #7a8eaa; margin-bottom: 8px; }
    .footer-text { font-size: 11.5px; color: #5b6f8a; line-height: 1.9; }
    .footer-text .highlight { color: #e84057; font-weight: 600; }


    .toast {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: #1a2740; color: #fff; padding: 13px 22px; border-radius: 10px;
      font-size: 13.5px; font-weight: 500; display: flex; align-items: center; gap: 10px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.18); opacity: 0; pointer-events: none;
      transition: opacity 0.3s, transform 0.3s; z-index: 999; white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast svg { width: 16px; height: 16px; flex-shrink: 0; }
    .toast.success svg { stroke: #28c76f; }
    .toast.error svg { stroke: #e84057; }

    
    @media print {
      .topbar, .sidebar, .page-header, .add-row-btn, .row-delete, .btn-ghost, .btn-primary, .btn-success { display: none !important; }
      .main { margin-left: 0; padding: 0; }
      .invoice-card { box-shadow: none; border-radius: 0; max-width: 100%; padding: 24px; }
      .editable, .table-input { border-bottom-color: transparent !important; background: transparent !important; }
    }
  </style>
</head>
<body>


<header class="topbar">
  <div class="logo">
    <svg viewBox="0 0 32 32" fill="none">
      <line x1="16" y1="2" x2="16" y2="30" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <path d="M10 9c0-3.3 2.7-6 6-6s6 2.7 6 6c0 4-6 8-6 8s-6-4-6-8z" stroke="white" stroke-width="1.8" fill="none" stroke-linecap="round"/>
      <path d="M9 15c-3.5 1.5-4.5 4.5-2 6.5s5.5 1.5 9-1" stroke="white" stroke-width="1.7" fill="none" stroke-linecap="round"/>
      <path d="M23 15c3.5 1.5 4.5 4.5 2 6.5s-5.5 1.5-9-1" stroke="white" stroke-width="1.7" fill="none" stroke-linecap="round"/>
      <path d="M9 21c-3 1.5-3 4-1 6s5 2 8 2" stroke="white" stroke-width="1.7" fill="none" stroke-linecap="round"/>
      <path d="M23 21c3 1.5 3 4 1 6s-5 2-8 2" stroke="white" stroke-width="1.7" fill="none" stroke-linecap="round"/>
    </svg>
    CLINIQ
  </div>
  <input class="topbar-search" type="text" placeholder="Search patients, invoices…"/>
</header>

<div class="layout">

  
  <nav class="sidebar">
    <div class="user-card">
      <div class="avatar">MC</div>
      <div>
        <div class="user-name">Curitana, MC</div>
        <div class="user-role">Lab Administrator</div>
      </div>
    </div>
    <div style="margin-top:10px;">
      <div class="nav-item" onclick="setNav(this)">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
        Overview
      </div>
      <div class="nav-item" onclick="setNav(this)">
        <svg viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </div>
    </div>
    <div class="nav-group-label">Management</div>
    <div class="nav-item" onclick="setNav(this)">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Test Catalog
    </div>
    <div class="nav-item" onclick="setNav(this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
      Lab Requests
    </div>
    <div class="nav-item active" onclick="setNav(this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 6v6l4 2"/></svg>
      Billing
    </div>
    <div class="nav-group-label">Reports</div>
    <div class="nav-item" onclick="setNav(this)">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Analytics
    </div>
    <div class="nav-signout" onclick="showToast('You have been signed out.','success')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Sign Out
    </div>
    <div class="sidebar-emblem">
      <svg viewBox="0 0 48 48" fill="none">
        <line x1="24" y1="4" x2="24" y2="44" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M16 13c0-4.4 3.6-8 8-8s8 3.6 8 8c0 5-8 11-8 11s-8-6-8-11z" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M14 23c-5 2-6 6-3 9s8 2 13-1" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M34 23c5 2 6 6 3 9s-8 2-13-1" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M14 32c-4 2-4 5-2 8s7 3 12 3" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M34 32c4 2 4 5 2 8s-7 3-12 3" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
  </nav>

  <main class="main">


    <div class="page-header">
      <div class="page-title">Billing / Invoice #INV-2604</div>
      <div class="page-actions">
        <button class="btn-ghost" onclick="window.print()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print
        </button>
        <button class="btn-ghost" onclick="exportPDF()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Export PDF
        </button>
        <button class="btn-success" onclick="markAsPaid()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Mark as Paid
        </button>
      </div>
    </div>

    
    <div class="invoice-card" id="invoiceCard">

  
      <div class="inv-header">
        <div>
          <div class="inv-logo">
            <svg viewBox="0 0 32 32" fill="none">
              <line x1="16" y1="2" x2="16" y2="30" stroke="#3a4f72" stroke-width="2" stroke-linecap="round"/>
              <path d="M10 9c0-3.3 2.7-6 6-6s6 2.7 6 6c0 4-6 8-6 8s-6-4-6-8z" stroke="#3a4f72" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <path d="M9 15c-3.5 1.5-4.5 4.5-2 6.5s5.5 1.5 9-1" stroke="#3a4f72" stroke-width="1.7" fill="none" stroke-linecap="round"/>
              <path d="M23 15c3.5 1.5 4.5 4.5 2 6.5s-5.5 1.5-9-1" stroke="#3a4f72" stroke-width="1.7" fill="none" stroke-linecap="round"/>
              <path d="M9 21c-3 1.5-3 4-1 6s5 2 8 2" stroke="#3a4f72" stroke-width="1.7" fill="none" stroke-linecap="round"/>
              <path d="M23 21c3 1.5 3 4 1 6s-5 2-8 2" stroke="#3a4f72" stroke-width="1.7" fill="none" stroke-linecap="round"/>
            </svg>
            <span class="inv-logo-name">CLINIQ</span>
          </div>
          <div style="margin-top:12px;">
            <div class="inv-clinic"><input class="editable" style="font-weight:700;font-size:13px;color:#1a2740;" value="St. Luke's Family Clinic"/></div>
            <div class="inv-clinic-sub">
              <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="Buhay na Tubig, Imus Cavite"/><br>
              <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="09654875632"/><br>
              <input class="editable" style="font-size:11.5px;color:#7a8eaa;" value="PhilHealth Accredited Clinic"/>
            </div>
          </div>
        </div>
        <div class="inv-title-block">
          <div class="inv-title">INVOICE</div>
          <div class="inv-meta">
            INVOICE &nbsp;<span>#<input class="editable" id="invNum" style="font-weight:600;color:#1a2740;font-size:11.5px;width:80px;" value="INV-2604"/></span><br>
            DATE ISSUED &nbsp;<span><input class="editable" id="invIssued" style="font-weight:600;color:#1a2740;font-size:11.5px;width:90px;" value="Jan-Apr-2026"/></span><br>
            DUE DATE &nbsp;<span class="due-red"><input class="editable" id="invDue" style="font-weight:700;color:#e84057;font-size:11.5px;width:90px;" value="April 30, 2026"/></span>
          </div>
          <div id="statusBadge" class="badge-unpaid" onclick="markAsPaid()" title="Click to mark as paid">UNPAID</div>
