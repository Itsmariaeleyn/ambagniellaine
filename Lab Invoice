<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CLINIQ – Statement of Account</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'DM Sans', sans-serif; background: #f0f4f2; color: #1a2e25; }

    :root {
      --green: #4caf87;
      --green-dark: #3a9270;
      --green-light: #6dc9a3;
      --green-bg: #eaf5ef;
      --green-border: #b4deca;
      --red: #e84057;
      --red-bg: #fde8eb;
      --navy: #1a2e25;
      --sidebar-bg: #3a9270;
      --topbar-bg: #5bb891;
    }

    .topbar {
      position: fixed; top: 0; left: 0; right: 0; height: 52px;
      background: var(--topbar-bg); display: flex; align-items: center;
      padding: 0 20px; gap: 14px; z-index: 200;
    }
    .logo { display: flex; align-items: center; gap: 9px; color: #fff; font-size: 18px; font-weight: 800; letter-spacing: 2px; user-select: none; }
    .logo svg { width: 26px; height: 26px; }
    .topbar-search {
      flex: 1; max-width: 420px; height: 32px;
      background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);
      border-radius: 5px; padding: 0 12px; color: #fff; font-size: 13px; font-family: inherit; outline: none;
    }
    .topbar-search::placeholder { color: rgba(255,255,255,0.55); }

    
    .layout { display: flex; padding-top: 52px; min-height: 100vh; }

  
    .sidebar {
      width: 200px; flex-shrink: 0; background: var(--sidebar-bg);
      position: fixed; top: 52px; left: 0; bottom: 0;
      display: flex; flex-direction: column; overflow-y: auto;
    }
    .user-card {
      display: flex; align-items: center; gap: 10px;
      padding: 14px; background: var(--green-dark); margin: 10px 10px 0; border-radius: 8px;
    }
    .avatar { width: 36px; height: 36px; background: #2d7358; border-radius: 7px; color: #fff; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .user-name { color: #fff; font-size: 13px; font-weight: 600; line-height: 1.2; }
    .user-role { color: rgba(255,255,255,0.6); font-size: 10.5px; }
    .nav-group-label { color: rgba(255,255,255,0.45); font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 14px 16px 4px; }
    .nav-item { display: flex; align-items: center; gap: 9px; padding: 9px 16px; color: rgba(255,255,255,0.75); font-size: 13px; font-weight: 500; cursor: pointer; border-left: 3px solid transparent; transition: background 0.12s, color 0.12s; user-select: none; }
    .nav-item:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .nav-item.active { background: rgba(255,255,255,0.15); color: #fff; border-left-color: #fff; }
    .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; opacity: 0.8; }
    .nav-item.active svg { opacity: 1; }
    .nav-signout { display: flex; align-items: center; gap: 9px; padding: 10px 16px; color: rgba(255,255,255,0.65); font-size: 13px; cursor: pointer; border-left: 3px solid transparent; transition: background 0.12s; }
    .nav-signout:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .nav-signout svg { width: 15px; height: 15px; }
    .sidebar-emblem { text-align: center; padding: 16px 0 20px; opacity: 0.18; }
    .sidebar-emblem svg { width: 60px; height: 60px; }

  
    .main { margin-left: 200px; flex: 1; padding: 30px 36px; min-height: calc(100vh - 52px); }

    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
    .page-title { font-size: 19px; font-weight: 700; color: var(--navy); }
    .page-actions { display: flex; gap: 10px; }
    .btn-ghost {
      background: #fff; border: 1.5px solid var(--green-border); border-radius: 7px;
      padding: 8px 16px; font-size: 13px; font-weight: 600; font-family: inherit;
      color: var(--green-dark); cursor: pointer; display: flex; align-items: center; gap: 6px;
      transition: background 0.13s;
    }
    .btn-ghost:hover { background: var(--green-bg); }
    .btn-ghost svg { width: 14px; height: 14px; }
    .btn-primary {
      background: var(--green); color: #fff; border: none; border-radius: 7px;
      padding: 8px 18px; font-size: 13px; font-weight: 600; font-family: inherit;
      cursor: pointer; display: flex; align-items: center; gap: 6px; transition: background 0.13s;
    }
    .btn-primary:hover { background: var(--green-dark); }
    .btn-primary svg { width: 14px; height: 14px; }

  
    .stmt-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 4px 24px rgba(40,100,70,0.1), 0 1px 4px rgba(0,0,0,0.05);
      max-width: 820px; margin: 0 auto; padding: 36px 40px 40px;
    }

    .stmt-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; }
    .stmt-logo { display: flex; align-items: center; gap: 10px; }
    .stmt-logo-name { font-size: 22px; font-weight: 800; color: var(--green); letter-spacing: 2px; }
    .stmt-title-block { text-align: right; }
    .stmt-title { font-size: 28px; font-weight: 800; color: var(--green); letter-spacing: 3px; margin-bottom: 8px; }
    .stmt-meta { font-size: 11.5px; color: #7a9e8a; line-height: 2; }
    .stmt-meta span { font-weight: 600; color: var(--navy); }

    .badge-due {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--red); color: #fff; font-size: 12px; font-weight: 700;
      padding: 7px 16px; border-radius: 20px; margin-top: 8px; cursor: default;
      letter-spacing: 0.3px;
    }

    .stmt-clinic-name { font-size: 13px; color: var(--navy); font-weight: 600; margin-bottom: 2px; }
    .stmt-clinic-sub { font-size: 11.5px; color: #7a9e8a; line-height: 1.8; }

    .stmt-divider { border: none; border-top: 1.5px solid #e4efe8; margin: 20px 0; }

    
    .stmt-parties { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 22px; }
    .party-label { font-size: 9.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #7a9e8a; margin-bottom: 6px; }
    .party-name { font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
    .party-detail { font-size: 11.5px; color: #7a9e8a; line-height: 1.8; }

   
    .summary-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      border: 1.5px solid var(--green-border); border-radius: 10px; overflow: hidden; margin-bottom: 22px;
    }
    .summary-box { padding: 14px 18px; border-right: 1.5px solid var(--green-border); background: var(--green-bg); }
    .summary-box:last-child { border-right: none; }
    .summary-box-label { font-size: 9.5px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--green-dark); margin-bottom: 6px; }
    .summary-box-val { font-size: 18px; font-weight: 800; color: var(--navy); font-family: 'DM Mono', monospace; }
    .summary-box-val.green { color: var(--green-dark); }
    .summary-box-val.red { color: var(--red); }

  
    .stmt-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-bottom: 20px; }
    .stmt-table thead tr { background: var(--green-bg); }
    .stmt-table th { padding: 9px 12px; text-align: left; font-size: 9.5px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--green-dark); border-bottom: 1.5px solid var(--green-border); }
    .stmt-table th.right { text-align: right; }
    .stmt-table td { padding: 9px 12px; border-bottom: 1px solid #f0f5f2; vertical-align: middle; }
    .stmt-table td.right { text-align: right; font-family: 'DM Mono', monospace; font-size: 11.5px; }
    .stmt-table tbody tr:hover { background: #fafcfb; }
    .stmt-table tbody tr.overdue { background: #fff0f2; }
    .stmt-table tbody tr.overdue td { color: var(--red); }
    .stmt-table tbody tr:last-child td { border-bottom: none; }

    .td-desc { font-weight: 500; color: var(--navy); }
    .td-desc-sub { font-size: 10.5px; color: #9ab8a4; margin-top: 2px; }
    .td-paid { color: var(--green-dark); font-weight: 600; }
    .td-balance-red { color: var(--red); font-weight: 700; }

   
    .editable {
      border: none; outline: none; font-family: inherit; background: transparent;
      border-bottom: 1.5px dashed transparent; transition: border-color 0.15s; padding: 1px 2px; width: 100%;
    }
    .editable:hover { border-bottom-color: #9ad4bb; }
    .editable:focus { border-bottom-color: var(--green); background: #f4fbf7; border-radius: 3px 3px 0 0; }

    .table-input {
      border: none; outline: none; font-family: inherit; background: transparent;
      border-bottom: 1.5px dashed transparent; transition: border-color 0.15s; padding: 1px 2px;
      font-size: 12px; width: 100%;
    }
    .table-input:hover { border-bottom-color: #9ad4bb; }
    .table-input:focus { border-bottom-color: var(--green); background: #f4fbf7; border-radius: 3px 3px 0 0; }
    .table-input.right { text-align: right; font-family: 'DM Mono', monospace; }

    .row-del {
      background: none; border: none; cursor: pointer; color: #c0d4c8;
      padding: 4px; border-radius: 4px; transition: color 0.13s, background 0.13s;
    }
    .row-del:hover { color: var(--red); background: var(--red-bg); }
    .row-del svg { width: 13px; height: 13px; display: block; }

    .add-row-btn {
      background: none; border: 1.5px dashed var(--green-border); border-radius: 7px;
      color: #7a9e8a; font-size: 12px; font-weight: 600; font-family: inherit;
      padding: 8px 16px; cursor: pointer; width: 100%; margin-bottom: 20px;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .add-row-btn:hover { border-color: var(--green); color: var(--green-dark); background: var(--green-bg); }


    .total-due-wrap { display: flex; justify-content: flex-end; margin-bottom: 22px; }
    .total-due-box {
      background: var(--red); border-radius: 10px; padding: 18px 28px; text-align: center;
      min-width: 220px;
    }
    .total-due-label { font-size: 9px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.8); margin-bottom: 4px; }
    .total-due-val { font-size: 28px; font-weight: 800; color: #fff; font-family: 'DM Mono', monospace; }
    .total-due-sub { font-size: 10px; color: rgba(255,255,255,0.75); margin-top: 4px; }


    .ack-box {
      background: #f6fbf8; border: 1px solid var(--green-border); border-radius: 8px;
      padding: 13px 16px; font-size: 11.5px; color: #6a9478; line-height: 1.7;
    }

    
    .toast {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: #1a2e25; color: #fff; padding: 13px 22px; border-radius: 10px;
      font-size: 13.5px; font-weight: 500; display: flex; align-items: center; gap: 10px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.18); opacity: 0; pointer-events: none;
      transition: opacity 0.3s, transform 0.3s; z-index: 999; white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast svg { width: 16px; height: 16px; flex-shrink: 0; }
    .toast.success svg { stroke: #4caf87; }
    .toast.error svg { stroke: #e84057; }

    @media print {
      .topbar, .sidebar, .page-header, .add-row-btn, .row-del { display: none !important; }
      .main { margin-left: 0; padding: 0; }
      .stmt-card { box-shadow: none; border-radius: 0; max-width: 100%; padding: 20px; }
      .editable, .table-input { border-bottom-color: transparent !important; background: transparent !important; }
    }
  </style>
</head>
