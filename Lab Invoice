            <input class="editable" style="font-size:11.5px;color:#7a9e8a;" value="09654875632"/><br>
            <input class="editable" style="font-size:11.5px;color:#7a9e8a;" value="PhilHealth Accredited Clinic"/>
          </div>
        </div>
      </div>

     
      <div class="summary-grid">
        <div class="summary-box">
          <div class="summary-box-label">Total Invoiced</div>
          <div class="summary-box-val" id="sumInvoiced">₱87,600</div>
        </div>
        <div class="summary-box">
          <div class="summary-box-label">Paid</div>
          <div class="summary-box-val green" id="sumPaid">₱68,200</div>
        </div>
        <div class="summary-box">
          <div class="summary-box-label">Balance Due</div>
          <div class="summary-box-val red" id="sumBalance">₱19,400</div>
        </div>
        <div class="summary-box">
          <div class="summary-box-label">Savings</div>
          <div class="summary-box-val green" id="sumSavings">₱4,840</div>
        </div>
      </div>

    
      <table class="stmt-table">
        <thead>
          <tr>
            <th style="width:90px;">DATE</th>
            <th style="width:90px;">INVOICE #</th>
            <th>DESCRIPTION</th>
            <th class="right" style="width:80px;">CHARGES</th>
            <th class="right" style="width:80px;">PAYMENT</th>
            <th class="right" style="width:80px;">BALANCE</th>
            <th style="width:32px;"></th>
          </tr>
        </thead>
        <tbody id="stmtTableBody"></tbody>
      </table>

      <button class="add-row-btn" onclick="addRow()">+ Add Transaction</button>

      
      <div class="total-due-wrap">
        <div class="total-due-box">
          <div class="total-due-label">Total Balance Due</div>
          <div class="total-due-val" id="totalDueVal">₱19,400</div>
          <div class="total-due-sub">Due on <input class="editable" id="dueDate" style="font-size:10px;color:rgba(255,255,255,0.85);width:90px;text-align:center;" value="April 30, 2026"/></div>
        </div>
      </div>

      
      <div class="ack-box">
        <textarea class="editable" rows="2" style="font-size:11.5px;color:#6a9478;resize:none;width:100%;line-height:1.7;">Acknowledgment: This statement reflects all transactions between St. Luke's Family Clinic and MetroMed Diagnostics Corp. from January to April 2026. For disputes or inquiries, please contact billing@metromed.com.ph within 10 days of receipt.</textarea>
      </div>

    </div>
  </main>
</div>


<div class="toast" id="toast">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" id="toastIcon">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
  <span id="toastMsg">Done!</span>
</div>

<script>

  function setNav(el) {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    el.classList.add('active');
  }


  const initialRows = [
    { date: 'Jan 5, 2026', inv: 'INV-2601', desc: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', charge: 17400, payment: 17400, overdue: false },
    { date: 'Jan 5, 2026', inv: 'INV-2601', desc: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', charge: 17400, payment: 17400, overdue: false },
    { date: 'Jan 5, 2026', inv: 'INV-2601', desc: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', charge: 17400, payment: 17400, overdue: false },
    { date: 'Jan 5, 2026', inv: 'INV-2601', desc: 'January 2026 Lab Services', detail: 'Allows: CBC, Lipid, UA, HbA1c, Thyroid', charge: 17400, payment: 0,     overdue: true  },
  ];

  let rowId = 0;

  function fmt(n) {
    return '₱' + parseFloat(n || 0).toLocaleString('en-PH', { minimumFractionDigits: 0 });
  }

  function addRow(data = {}) {
    const tbody = document.getElementById('stmtTableBody');
    rowId++;
    const id = rowId;
    const charge  = data.charge  !== undefined ? data.charge  : 0;
    const payment = data.payment !== undefined ? data.payment : 0;
    const balance = charge - payment;
    const overdue = data.overdue || false;

    const tr = document.createElement('tr');
    tr.id = 'srow-' + id;
    if (overdue) tr.classList.add('overdue');
    tr.innerHTML = `
      <td><input class="table-input" style="width:78px;" value="${data.date || ''}" placeholder="Date"/></td>
      <td><input class="table-input" style="width:72px;" value="${data.inv || ''}" placeholder="INV-XXXX"/></td>
      <td>
        <div class="td-desc"><input class="table-input" value="${data.desc || ''}" placeholder="Description"/></div>
        <div class="td-desc-sub"><input class="table-input" style="font-size:10.5px;color:#9ab8a4;" value="${data.detail || ''}" placeholder="Details…"/></div>
      </td>
      <td class="right"><input class="table-input right" type="number" min="0" value="${charge}" oninput="recalc()" style="width:68px;"/></td>
      <td class="right ${payment > 0 ? 'td-paid' : ''}"><input class="table-input right" type="number" min="0" value="${payment}" oninput="recalcRow(${id})" style="width:68px;"/></td>
      <td class="right ${balance > 0 ? 'td-balance-red' : ''}" id="bal-${id}">${balance > 0 ? fmt(balance) : '₱0'}</td>
      <td>
        <button class="row-del" onclick="deleteRow(${id})" title="Remove">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </button>
      </td>`;
    tbody.appendChild(tr);
    recalc();
  }

  function recalcRow(id) {
    const tr = document.getElementById('srow-' + id);
    if (!tr) return;
    const inputs = tr.querySelectorAll('input[type="number"]');
    const charge  = parseFloat(inputs[0]?.value) || 0;
    const payment = parseFloat(inputs[1]?.value) || 0;
    const balance = charge - payment;
    const balCell = document.getElementById('bal-' + id);
    balCell.textContent = balance > 0 ? fmt(balance) : '₱0';
    balCell.className = 'right ' + (balance > 0 ? 'td-balance-red' : '');
    tr.classList.toggle('overdue', balance > 0 && payment === 0);
    recalc();
  }

  function deleteRow(id) {
    document.getElementById('srow-' + id)?.remove();
    recalc();
  }

  function recalc() {
    let totalCharge = 0, totalPayment = 0;
    document.querySelectorAll('#stmtTableBody tr').forEach(tr => {
      const inputs = tr.querySelectorAll('input[type="number"]');
      totalCharge  += parseFloat(inputs[0]?.value) || 0;
      totalPayment += parseFloat(inputs[1]?.value) || 0;
    });
    const balanceDue = totalCharge - totalPayment;
    const savings    = totalCharge * 0.055;

    document.getElementById('sumInvoiced').textContent = fmt(totalCharge);
    document.getElementById('sumPaid').textContent     = fmt(totalPayment);
    document.getElementById('sumBalance').textContent  = fmt(balanceDue);
    document.getElementById('sumSavings').textContent  = fmt(savings);
    document.getElementById('totalDueVal').textContent = fmt(balanceDue);
    document.getElementById('badgeAmt').textContent    = fmt(balanceDue);
  }

  function saveStatement() {
    showToast('Statement saved successfully!', 'success');
  }

  function exportPDF() {
    showToast('Preparing PDF export…', 'success');
    setTimeout(() => window.print(), 400);
  }

  
  let toastTimer;
  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    const icon  = document.getElementById('toastIcon');
    document.getElementById('toastMsg').textContent = msg;
    toast.className = 'toast ' + type;
    icon.innerHTML = type === 'success'
      ? `<polyline points="20 6 9 17 4 12"/>`
      : `<circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  initialRows.forEach(r => addRow(r));
</script>
</body>
</html>
